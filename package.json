{
  "name": "themis-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Themis platform control plane and operations surface for nodes, scheduling, governance, and on-call workflows.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "themis-platform": "./themis-platform"
  },
  "scripts": {
    "themis:platform": "tsx src/cli/platform-main.ts",
    "test": "node --test --import tsx src/**/*.test.ts apps/**/*.test.js",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "dev:platform": "tsx watch --clear-screen=false src/server/platform-main.ts",
    "start:platform": "node dist/server/platform-main.js"
  },
  "dependencies": {
    "mysql2": "^3.15.3",
    "themis-contracts": "file:../themis-contracts"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
